# Copy to .env.local and fill in. NEVER commit real secrets.

# AI provider (Google Gemini). Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Which AI provider to use. Keeps the model swappable. Options: gemini (default)
AI_PROVIDER=gemini

# Optional: Upstash Redis (serverless). Leave blank to use the in-memory cache for local dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Data source for the Swiggy adapter. Options: mock (default) | mcp (later, real Swiggy access)
SWIGGY_DATA_SOURCE=mock
